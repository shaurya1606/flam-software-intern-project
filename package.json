{
  "name": "queuectl",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "daemon": "node dist/src/daemon/daemon.js",
    "dashboard": "node dashboard/server.js",
    "start": "concurrently \"npm run daemon\" \"npm run dashboard\"",
    "cli": "node dist/bin/queuectl.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "bin": {
    "queuectl": "./dist/bin/queuectl.js"
  },
  "keywords": [
  "queue",
  "job-queue",
  "cli",
  "worker",
  "background-jobs",
  "sqlite",
  "typescript",
  "scheduler",
  "daemon",
  "queuectl"
],
  "author": "shaurya srivastava",
  "description": "A lightweight CLI-based background job queue with SQLite persistence, worker management, retries, dead-letter queue, and a live monitoring dashboard.",
  "dependencies": {
    "better-sqlite3": "^12.4.1",
    "bullmq": "^5.63.0",
    "commander": "^14.0.2",
    "concurrently": "^10.0.3",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "ioredis": "^5.8.2",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.0",
    "@vitest/coverage-v8": "^4.1.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
